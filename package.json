{
  "name": "ai-access-hub",
  "version": "1.0.0",
  "description": "Local AI access hub – unified API for multiple AI providers",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "doctor": "tsx src/doctor.ts",
    "test": "npm run test:quota && npm run test:dashboard",
    "test:dashboard": "playwright test tests/dashboard.spec.ts",
    "test:quota": "playwright test tests/quota.spec.ts",
    "verify": "npm run typecheck && npm run build && npm run test",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.2",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
