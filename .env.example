# ─── Hub binding ─────────────────────────────────────────────────────────────
HUB_HOST=127.0.0.1
HUB_PORT=3000

# Admin bearer token (generate a random string – min 32 chars)
HUB_ADMIN_TOKEN=change-me-to-a-long-random-secret-token

# Master encryption key for secrets at rest (min 32 chars, keep secret)
HUB_SECRET_KEY=change-me-to-a-long-random-encryption-key

# Log level: debug | info | warn | error
HUB_LOG_LEVEL=info

# Data and log directories (resolved relative to project root if not absolute)
HUB_DATA_DIR=./data
HUB_LOG_DIR=./logs
HUB_AUTO_OPEN_DASHBOARD=true

# ─── Mode flags ───────────────────────────────────────────────────────────────
# FREE_ONLY_MODE=true      # only use free/local providers
# LOCAL_ONLY_MODE=false    # only route to local endpoints
# PREMIUM_ENABLED=false    # allow membership/paid lanes

# ─── Local endpoint ───────────────────────────────────────────────────────────
LOCAL_ENABLED=true
LOCAL_BASE_URL=http://localhost:1234/v1
# Comma-separated list of known local model IDs (optional, auto-discovered if omitted)
# LOCAL_MODELS=llama-3.3-70b,codestral-22b

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_ENABLED=true
GEMINI_API_KEY=

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_ENABLED=true
GROQ_API_KEY=

# ─── OpenRouter (free models only) ───────────────────────────────────────────
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
# Site URL and name sent in headers (optional, helps OpenRouter identify usage)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=ai-access-hub

# ─── Mistral ──────────────────────────────────────────────────────────────────
MISTRAL_ENABLED=true
MISTRAL_API_KEY=

# ─── Cerebras ─────────────────────────────────────────────────────────────────
CEREBRAS_ENABLED=true
CEREBRAS_API_KEY=

# ─── Cloudflare Workers AI ───────────────────────────────────────────────────
CLOUDFLARE_ENABLED=true
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional AI Gateway name (blank = use Workers AI directly)
CLOUDFLARE_GATEWAY_NAME=

# ─── GitHub Models ────────────────────────────────────────────────────────────
GITHUB_MODELS_ENABLED=true
GITHUB_MODELS_TOKEN=

# ─── SambaNova ────────────────────────────────────────────────────────────────
SAMBANOVA_ENABLED=true
SAMBANOVA_API_KEY=

# ─── Cohere ───────────────────────────────────────────────────────────────────
COHERE_ENABLED=true
COHERE_API_KEY=

# ─── Fireworks ────────────────────────────────────────────────────────────────
FIREWORKS_ENABLED=true
FIREWORKS_API_KEY=

# ─── GitHub Copilot (membership lane) ────────────────────────────────────────
# Requires interactive sign-in: run `POST /v1/admin/copilot-auth/init` from dashboard
COPILOT_ENABLED=false

# ─── Codex / OpenAI (membership lane) ────────────────────────────────────────
# API mode: set OPENAI_API_KEY.
# Local CLI mode: leave OPENAI_API_KEY blank and enable CODEX_CLI_ENABLED after
# logging into the Codex CLI on this machine.
CODEX_ENABLED=false
OPENAI_API_KEY=
CODEX_CLI_ENABLED=false
CODEX_CLI_PATH=codex
# On Windows, `codex.cmd` is the safer explicit value if PATH resolution is picky.
CODEX_CLI_TIMEOUT_MS=120000

# ─── Optional providers ───────────────────────────────────────────────────────
# HUGGINGFACE_ENABLED=false
# HUGGINGFACE_API_KEY=
